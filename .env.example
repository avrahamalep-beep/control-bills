# Neon — string חיבור (Connection string)מ Prisma: postgresql://...
DATABASE_URL="postgresql://user:pass@host.neon.tech/neondb?sslmode=require"

# Auth.js: openssl rand -base64 32
AUTH_SECRET=""

# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web)
# Redirect: http://localhost:3000/api/auth/callback/google
# (o en Render: https://TU-APP.onrender.com/api/auth/callback/google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Alternativa (mismo valor):
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# URL ציבורי: https://yourapp.onrender.com
AUTH_URL="https://localhost:3000"
NEXTAUTH_URL="https://localhost:3000"

# אימיילים מותרים (רשימה מופרדת בפסיק/רווח)
